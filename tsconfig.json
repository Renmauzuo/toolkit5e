{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "declaration": true,
    "rootDir": "./packages",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node16"
  },
  "include": ["packages/**/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
