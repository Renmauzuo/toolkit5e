{
  "name": "toolkit5e",
  "version": "1.0.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build && node -e \"require('fs').copyFileSync('packages/statblock/src/statblock.css', 'packages/statblock/dist/statblock.css')\"",
    "watch": "tsc --build --watch",
    "test": "vitest --run",
    "format": "prettier --write \"packages/*/src/**/*.ts\""
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "typescript": "^6.0.2",
    "vitest": "^0.34.6"
  }
}
