{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "paths": {
      "@toolkit5e/base": ["../base/src/index.ts"]
    }
  },
  "references": [
    { "path": "../base" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
